# Copy to .env and fill in. NEVER commit the real .env.

# RUNTIME token (pk.…). From Mapbox account → Tokens → Default public token.
# Before shipping: create a NEW token and add a URL/app restriction.
MAPBOX_PUBLIC_TOKEN=pk.your_public_token_here

# BUILD-ONLY token (sk.…) with the "Downloads:Read" scope.
# Mapbox account → Tokens → Create a token → enable DOWNLOADS:READ secret scope.
# Used by the @rnmapbox/maps config plugin to fetch the native SDK. Do NOT ship it.
MAPBOX_DOWNLOAD_TOKEN=sk.your_secret_download_token_here

# RevenueCat PUBLIC SDK keys (one per platform) — for the character store.
# RevenueCat dashboard → Project → API keys → "Public app-specific" keys.
# Leave blank to run in dev mode (purchases granted locally, no real charges).
REVENUECAT_IOS_KEY=appl_your_ios_public_sdk_key
REVENUECAT_ANDROID_KEY=goog_your_android_public_sdk_key

# Supabase — the Tickets backend (balances/ledger/RPCs).
# Project Settings → API. The anon key is PUBLIC (safe in the app). Leave blank
# to run with Tickets disabled (the app degrades gracefully).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
#
# The following are SERVER-ONLY secrets for the edge functions. Do NOT put them
# in the app build — set them with `supabase secrets set` (see TICKETS.md):
#   SUPABASE_SERVICE_ROLE_KEY, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
